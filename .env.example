ROBOFLOW_API_KEY=replace_me
ROBOFLOW_DATASET_URL=https://universe.roboflow.com/workspace-slug/project-slug/dataset/1
DATASET_FORMAT=coco

MODEL_TASK=detection
MODEL_VARIANT=medium

EPOCHS=100
BATCH_SIZE=8
GRAD_ACCUM_STEPS=2
LR=1e-4
LR_ENCODER=
WEIGHT_DECAY=
NUM_WORKERS=
DEVICE=
RESUME=

OUTPUT_DIR=/workspace/output
DATASET_DIR=/workspace/dataset
FORCE_RERUN=false
TRAINING_COMPLETE_FILE=
KEEP_ALIVE_AFTER_TRAINING=true
POST_TRAINING_SHELL=/bin/bash

TENSORBOARD=true
WANDB=false
PROJECT=rfdetr
RUN=
EARLY_STOPPING=false
USE_EMA=
RUN_TEST=
GRADIENT_CHECKPOINTING=

EXPORT_ONNX=false
EXTRA_TRAIN_ARGS_JSON={"eval_interval":5,"log_per_class_metrics":false,"pin_memory":true,"persistent_workers":true,"prefetch_factor":4}
MODEL_INIT_JSON={}
EXTRA_EXPORT_ARGS_JSON={}
